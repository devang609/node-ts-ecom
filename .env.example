NODE_ENV=development
PORT=3000
LOG_LEVEL=info
SWAGGER_ENABLED=true

# Postgres (required in dev/prod)
DATABASE_URL=postgresql://user:password@host:5432/flipmart
DB_SSL=false

# JWT-RSA keys (required in dev/prod)
JWT_ISSUER=flipmart-auth
JWT_AUDIENCE=flipmart
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem

# Token TTLs
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Cookies
COOKIE_SECURE=false
